# vibeswipe — web app environment.
# Copy to `.env.local` and fill in. NEVER commit real values (.env* is gitignored).

# ── Spotify OAuth (https://developer.spotify.com/dashboard) ──
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
NEXT_PUBLIC_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3000

# ── Supabase (https://supabase.com/dashboard → Project Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=
# Publishable/anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service-role secret — SERVER ONLY. Bypasses RLS. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── Last.fm (https://www.last.fm/api/account/create) — optional ──
# Powers the "people who play X also play Y" recommendation strategy.
LASTFM_API_KEY=

# ── Anthropic (optional) — AI playlist-seed interpretation ──
ANTHROPIC_API_KEY=

# ── Corpus ingest gate ──
# Leave empty for local dev. Set to a random secret in production to require
# the x-ingest-token header on /api/corpus/ingest (mobile sends it via
# EXPO_PUBLIC_CORPUS_INGEST_TOKEN). Prevents anonymous writes to the corpus.
CORPUS_INGEST_TOKEN=
