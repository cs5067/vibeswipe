# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real secrets. (.env.example is the committed template.)
.env
.env.*
!.env.example

# local agent/editor config — kept out of the public repo
.claude/
.mcp.json

# internal planning / strategy / agent docs — kept local, not published
AGENTS.md
CLAUDE.md
HANDOFF.md
PLAN.md
docs/
council-report-*.html
council-transcript-*.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
